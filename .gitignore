# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# artefactos de experimentos locales (ids de pruebas contra APIs externas)
scripts/.apollo_test_*

# la DB real vive un nivel arriba (../isps.db); si algo corre sqlite3 con ruta
# relativa por accidente aquí, crea este archivo vacío fantasma. Nunca es la DB real.
/isps.db

# typescript
*.tsbuildinfo
next-env.d.ts
