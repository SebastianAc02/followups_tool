followupsonepay.duckdns.org {
	# lb_try_duration: si followups-web esta momentaneamente inalcanzable (recreacion
	# del contenedor en un deploy), Caddy reintenta hasta 10s en vez de tirar 502 de una.
	# next start levanta en ~250ms, asi que 10s cubre de sobra el parpadeo del deploy y
	# el usuario ve una peticion un pelo mas lenta en vez de "no me deja entrar".
	reverse_proxy followups-web:3000 {
		lb_try_duration 10s
		lb_try_interval 250ms
	}
}

# MCP del panel: login OAuth (2026-07-23, docs/superpowers/specs/2026-07-23-mcp-oauth-login-design.md).
# El MCP ya no vive en el contenedor `mcp` standalone (token bearer manual): pasa a ser una
# route de followups-web (app/api/mcp), protegida por el plugin `mcp` de Better Auth --
# Camilo pega la URL en Claude y se loguea con su cuenta de la tool, sin copiar tokens. Este
# subdominio sigue vivo (Camilo ya lo tenia guardado) pero apunta al mismo contenedor que el
# dominio principal, no a `mcp:3900`. El contenedor `mcp` standalone (docker-compose.mcp.yml)
# queda sin trafico real -- se apaga aparte, como paso de deploy, no se borra el codigo.
mcp.followupsonepay.duckdns.org {
	reverse_proxy followups-web:3000 {
		lb_try_duration 10s
		lb_try_interval 250ms
	}
}
