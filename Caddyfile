followupsonepay.duckdns.org {
	# lb_try_duration: si followups-web esta momentaneamente inalcanzable (recreacion
	# del contenedor en un deploy), Caddy reintenta hasta 10s en vez de tirar 502 de una.
	# next start levanta en ~250ms, asi que 10s cubre de sobra el parpadeo del deploy y
	# el usuario ve una peticion un pelo mas lenta en vez de "no me deja entrar".
	reverse_proxy followups-web:3000 {
		lb_try_duration 10s
		lb_try_interval 250ms
	}
}

# MCP server del panel (Fase 3): puerta publica con TLS para que un cliente MCP externo
# (ej. Camilo) queree los ISPs sin instalar nada ni entrar a Tailscale. Caddy termina TLS
# (cert automatico de Let's Encrypt, el subdominio resuelve por wildcard de DuckDNS a la IP
# del VPS) y proxea al contenedor `mcp` por la red interna `onepay`. La barrera de acceso
# es el token bearer que valida el propio server (MCP_TOKEN en .env.production); Caddy solo
# agrega el TLS. El bind del `ports:` en docker-compose.mcp.yml sigue siendo solo-Tailscale
# para admin; el trafico de Camilo entra por aca, no por ese puerto.
mcp.followupsonepay.duckdns.org {
	reverse_proxy mcp:3900
}
