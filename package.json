{
  "name": "followups-tool",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker": "node --env-file=.env.local --experimental-strip-types --experimental-loader ./scripts/resolve-ts-ext.mjs ./app/worker/index.ts",
    "migrate": "node --experimental-strip-types --experimental-loader ./scripts/resolve-ts-ext.mjs ./scripts/migrate.ts",
    "migrate:baseline": "node --experimental-strip-types --experimental-loader ./scripts/resolve-ts-ext.mjs ./scripts/baseline-migration.ts",
    "test": "ISPS_DB_PATH=:memory: node --experimental-strip-types --experimental-loader ./scripts/resolve-ts-ext.mjs --test \"app/db/*.test.ts\" \"app/lib/*.test.ts\" \"app/core/*.test.ts\" \"app/core/**/*.test.ts\" \"app/adapters/*.test.ts\" \"app/worker/*.test.ts\" \"app/campanas/**/*.test.ts\" \"app/cadencias/**/*.test.ts\" \"app/llamada/**/*.test.ts\" \"app/api/**/*.test.ts\" \"app/ui/*.test.ts\" \"app/cola/*.test.ts\" \"app/conectores/*.test.ts\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "better-auth": "^1.6.23",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.9",
    "radix-ui": "^1.6.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.3.2",
    "typescript": "^5"
  }
